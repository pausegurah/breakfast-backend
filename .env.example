# Server
PORT=3000
NODE_ENV=development

# Ulysses PMS credentials (NEVER commit real values)
ULYSSES_BASE_URL=https://publicapi-elpalace.ulysescloud.com
ULYSSES_CHAIN_ID=1
ULYSSES_PROPERTY_ID=1
ULYSSES_USER=CHANGE_ME
ULYSSES_PASS=CHANGE_ME

# Cache (0 = disabled, useful in development)
CACHE_TTL_MINUTES=4

# Security
# In production, set to comma-separated list of allowed IPs/domains
# Example: http://192.168.1.50,http://192.168.1.51
ALLOWED_ORIGINS=*
